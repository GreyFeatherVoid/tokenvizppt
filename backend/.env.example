TOKENVIZPPT_APP_ENV=development
TOKENVIZPPT_DATABASE_URL=postgresql+psycopg://tokenvizppt:tokenvizppt@localhost:15432/tokenvizppt
TOKENVIZPPT_REDIS_URL=redis://localhost:16379/0
TOKENVIZPPT_STORAGE_ROOT=../storage

# Frontend remains model-agnostic. These values are backend-only.
# Provider currently uses OpenAI-compatible chat completions.
TOKENVIZPPT_LLM_PROVIDER=openai
TOKENVIZPPT_LLM_MODEL=gpt-4o-mini
TOKENVIZPPT_LLM_API_KEY=replace-with-your-key

# Leave empty for official OpenAI. For compatible providers, use their /v1 base URL.
# Examples:
# TOKENVIZPPT_LLM_BASE_URL=https://api.openai.com/v1
# TOKENVIZPPT_LLM_BASE_URL=https://api.deepseek.com/v1
TOKENVIZPPT_LLM_BASE_URL=
TOKENVIZPPT_LLM_TEMPERATURE=0.7
TOKENVIZPPT_LLM_TIMEOUT_SECONDS=60

# Per-deck slide generation concurrency after the outline is planned.
# Higher values are faster but may trigger provider rate limits. Recommended: 3-5.
TOKENVIZPPT_GENERATION_SLIDE_CONCURRENCY=3

# Per-deck uploaded image analysis concurrency before planning.
# Higher values are faster but may trigger provider rate limits. Recommended: 2-4.
TOKENVIZPPT_IMAGE_ANALYSIS_CONCURRENCY=3

# AI image generation is backend-only and disabled by default.
# Enable only when the provider/key are configured and the deck needs generated visual anchors.
TOKENVIZPPT_AI_IMAGE_ENABLED=false
TOKENVIZPPT_AI_IMAGE_PROVIDER=openai
TOKENVIZPPT_AI_IMAGE_MODEL=gpt-image-2
TOKENVIZPPT_AI_IMAGE_API_KEY=replace-with-your-image-key
TOKENVIZPPT_AI_IMAGE_BASE_URL=
TOKENVIZPPT_AI_IMAGE_TIMEOUT_SECONDS=220
TOKENVIZPPT_AI_IMAGE_DEFAULT_SIZE=1536x1024
TOKENVIZPPT_AI_IMAGE_MAX_PER_DECK=2
